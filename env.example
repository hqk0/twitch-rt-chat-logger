# Twitch API Configuration
# You can get these from the Twitch Developer Console
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# The Twitch Channel to monitor
# CHANNEL_ID: numeric ID of the channel (use https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/ to find it)
# CHANNEL_NAME: username of the channel (lowercase)
CHANNEL_ID=12345678
CHANNEL_NAME=target_channel_name

# Notification Configuration (ntfy.sh)
# Choose a unique topic name (e.g., my_twitch_alerts_randomstring123)
# You can subscribe to this topic on your iPhone using the ntfy app
NTFY_TOPIC=your_secret_topic_name
# Optional: Self-hosted ntfy server URL (defaults to https://ntfy.sh)
NTFY_URL=https://ntfy.sh

# LINE Messaging API Configuration (Optional)
# If provided, notifications will also be sent via LINE
# Get Channel Access Token from LINE Developers Console > Messaging API > Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# Optional: Your User ID. If set, sends push message to you only.
# If NOT set, sends broadcast to all friends (uses more free tier quota if you have many friends).
# You can find your User ID in the "Basic settings" tab of the console.
LINE_USER_ID=U12345678...

# Legacy/Optional (Auto-generated in tokens.json usually)
# If you want to seed the initial tokens manually
# ACCESS_TOKEN=
# REFRESH_TOKEN=
