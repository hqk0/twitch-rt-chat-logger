# Twitch API Configuration
CLIENT_ID="your_twitch_client_id"
CLIENT_SECRET="your_twitch_client_secret"

# The Twitch Channel to monitor
CHANNEL_ID="numeric_channel_id"
CHANNEL_NAME="channel_username"

# Cloudflare Configuration (Optional, for archival automation)
CF_API_TOKEN="your_cloudflare_api_token"
CF_ACCOUNT_ID="your_cloudflare_account_id"
D1_DATABASE_ID="your_d1_database_id"

# Cloudflare R2 Storage (Optional, for remote chat JSON storage)
R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_bucket_name"

# Notification Configuration
NTFY_URL="https://ntfy.sh"
NTFY_TOPIC=""

# LINE Messaging API (Optional)
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_USER_ID=""
